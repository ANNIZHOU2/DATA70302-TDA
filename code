import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
import math
from sklearn.preprocessing import StandardScaler
from statsmodels.stats.outliers_influence import variance_inflation_factor
from statsmodels.tools.tools import add_constant

# --- 1. DATA LOADING & PRE-MERGE CLEANING ---

def load_and_clean_census(file_path, column_mapping):
    """Parses Nomis Census CSVs, cleans headers, and renames columns."""
    df = pd.read_csv(file_path, skiprows=7)
    df = df.rename(columns={'mnemonic': 'lsoa21cd'})
    return df[['lsoa21cd'] + list(column_mapping.keys())].rename(columns=column_mapping)

# Define column mappings based on literature and research focus
dep_map = {
    'Household is not deprived in any dimension': 'prop_dep_0',
    'Household is deprived in one dimension': 'prop_dep_1',
    'Household is deprived in two dimensions': 'prop_dep_2',
    'Household is deprived in three dimensions': 'prop_dep_3',
    'Household is deprived in four dimensions': 'prop_dep_4'
}

eth_map = {
    'Asian, Asian British or Asian Welsh': 'prop_ethnic_asian',
    'Black, Black British, Black Welsh, Caribbean or African': 'prop_ethnic_black',
    'Mixed or Multiple ethnic groups': 'prop_ethnic_mixed',
    'White': 'prop_ethnic_white',
    'Other ethnic group': 'prop_ethnic_other'
}

car_map = {
    'No cars or vans in household': 'prop_car_0',
    '1 car or van in household': 'prop_car_1',
    '2 cars or vans in household': 'prop_car_2',
    '3 or more cars or vans in household': 'prop_car_3_plus'
}

social_map = {
    'L1, L2 and L3 Higher managerial, administrative and professional occupations': 'prop_class_high',
    'L12 Semi-routine occupations': 'prop_class_semi_routine',
    'L13 Routine occupations': 'prop_class_routine',
    'L14.1 and L14.2 Never worked and long-term unemployed': 'prop_class_never_worked',
    'L15 Full-time students': 'prop_class_student'
}

econ_map = {
    'Economically active (excluding full-time students)': 'prop_econ_active',
    'Economically active and a full-time student': 'prop_econ_active_student',
    'Economically inactive': 'prop_econ_inactive'
}

# Load AHAH v5 as the baseline dataframe
ahah_df = pd.read_csv('ahah_v5.csv')[[
    'lsoa21cd', 'domain_r', 'fast_food', 'ahah', 
    'ahah_pct', 'domain_h', 'domain_e', 'domain_g'
]]

# Iterate and merge Census datasets
census_files = [
    ('census2021_deprivation.csv', dep_map),
    ('census2021_ethnicity.csv', eth_map),
    ('census2021_car_access.csv', car_map),
    ('census2021_social_class.csv', social_map),
    ('census2021_econ_activity.csv', econ_map)
]

final_df = ahah_df.copy()
for file, mapping in census_files:
    final_df = pd.merge(final_df, load_and_clean_census(file, mapping), on='lsoa21cd', how='inner')

# Drop rows with missing values to ensure distance matrix integrity for Ball Mapper
final_df = final_df.dropna()
final_df.to_csv('cleaned_data.csv', index=False)

# --- 2. EXPLORATORY DATA ANALYSIS (EDA) & TRANSFORMATIONS ---

def plot_distributions(df, columns, filename, color='skyblue', title_prefix="Original"):
    """Helper function to visualize distributions of key variables."""
    n_cols = 3
    n_rows = math.ceil(len(columns) / n_cols)
    plt.figure(figsize=(15, n_rows * 4))
    
    for i, var in enumerate(columns):
        plt.subplot(n_rows, n_cols, i + 1)
        sns.histplot(df[var], kde=True, color=color, bins=30)
        plt.title(f'{title_prefix} Dist: {var}', fontsize=12)
        plt.xlabel('Value')
        plt.ylabel('Frequency')
    
    plt.tight_layout()
    plt.savefig(filename)
    plt.close()

# Define core variables for visualization
viz_cols = [
    'ahah', 'prop_dep_4', 'prop_car_0', 'prop_ethnic_white', 
    'prop_ethnic_asian', 'prop_ethnic_black', 'prop_class_never_worked', 
    'prop_class_student', 'prop_econ_inactive'
]

# Generate baseline distribution plots
plot_distributions(final_df, viz_cols, 'original_distributions.png')

# Detect Outliers using IQR method
numeric_df = final_df.select_dtypes(include=[np.number])
Q1 = numeric_df.quantile(0.25)
Q3 = numeric_df.quantile(0.75)
IQR = Q3 - Q1
outlier_counts = ((numeric_df < (Q1 - 1.5 * IQR)) | (numeric_df > (Q3 + 1.5 * IQR))).sum()
print("\nOutlier counts per variable:\n", outlier_counts)

# Apply Square Root Transformation to address significant right-skewness
skewed_vars = [
    'prop_ethnic_asian', 'prop_ethnic_black', 'prop_ethnic_mixed', 'prop_ethnic_other',
    'prop_class_never_worked', 'prop_class_student', 'prop_econ_active_student', 'prop_dep_4'
]
df_transformed = final_df.copy()
df_transformed[skewed_vars] = np.sqrt(final_df[skewed_vars])

# Generate transformed distribution plots for comparison
plot_distributions(df_transformed, viz_cols, 'transformed_distributions.png', color='salmon', title_prefix="Transformed")

# --- 3. DIAGNOSTICS: CORRELATION & MULTICOLLINEARITY ---

# Candidate axes for Ball Mapper construction
axis_candidates = ['prop_car_0', 'prop_dep_4', 'prop_ethnic_white', 'prop_class_never_worked', 'prop_econ_inactive']

# Correlation Heatmap (Including the dependent variable domain_r)
plt.figure(figsize=(10, 8))
sns.heatmap(df_transformed[axis_candidates + ['domain_r']].corr(), annot=True, cmap='RdBu_r', center=0, fmt=".2f")
plt.title("Correlation Diagnostic: Axis Candidates vs. Retail Hazard Outcome")
plt.savefig('correlation_heatmap.png')
plt.show()

# Variance Inflation Factor (VIF) to detect redundancy among axes
X = add_constant(df_transformed[axis_candidates])
vif_df = pd.DataFrame()
vif_df["Variable"] = X.columns
vif_df["VIF"] = [variance_inflation_factor(X.values, i) for i in range(X.shape[1])]
print("\n--- Multicollinearity Check (VIF) ---")
